{
  "name": "mangal-platform",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "postinstall": "pnpm db:generate",
    "dev": "pnpm --parallel --filter @mangal/api --filter @mangal/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @mangal/db generate",
    "db:migrate": "pnpm --filter @mangal/db migrate",
    "db:seed": "pnpm --filter @mangal/db seed"
  },
  "devDependencies": { "typescript": "^5.7.3", "prettier": "^3.5.1" }
}
